# =============================================================================
# SpeedBox - DietPi Automation Overrides
# =============================================================================
# Ce fichier contient les lignes a modifier dans /boot/dietpi.txt
# AVANT le premier demarrage d'une image DietPi vierge.
#
# Instructions :
# 1. Flasher l'image DietPi officielle sur la carte SD
# 2. Monter la partition boot de la carte SD
# 3. Modifier /boot/dietpi.txt avec les valeurs ci-dessous
# 4. Copier Automation_Custom_Script.sh dans /boot/
# 5. Ejecter la carte SD et demarrer le Raspberry Pi
#
# Le Pi doit etre connecte en Ethernet avec acces internet (DHCP).
# SpeedBox sera installe automatiquement au premier boot (~5 minutes).
# =============================================================================

# --- Valeurs a modifier dans /boot/dietpi.txt ---

# Mot de passe root et dietpi (CHANGER EN PRODUCTION !)
AUTO_SETUP_GLOBAL_PASSWORD=SpeedBox2026!

# Langue et clavier
AUTO_SETUP_LOCALE=C.UTF-8
AUTO_SETUP_KEYBOARD_LAYOUT=fr
AUTO_SETUP_TIMEZONE=Europe/Paris

# Reseau : Ethernet + DHCP (defaut)
AUTO_SETUP_NET_ETHERNET_ENABLED=1
AUTO_SETUP_NET_WIFI_ENABLED=0

# Hostname
AUTO_SETUP_NET_HOSTNAME=SpeedBox

# Installation 100% automatique (pas de menu interactif)
AUTO_SETUP_AUTOMATED=1

# Activer le script d'installation custom
AUTO_SETUP_CUSTOM_SCRIPT_EXEC=1

# Attendre le reseau avant le setup (necessaire pour git clone)
AUTO_SETUP_BOOT_WAIT_FOR_NETWORK=1

# Mode console avec autologin
AUTO_SETUP_AUTOSTART_TARGET_INDEX=7
AUTO_SETUP_AUTOSTART_LOGIN_USER=root

# SSH actif (Dropbear par defaut)
AUTO_SETUP_SSH_SERVER_INDEX=-1

# Pas de survey
SURVEY_OPTED_IN=0
